[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = 4.2
reloadable = true

[libraries]
windows.debug.x86_64 = "res://addons/gdbridge/bin/gdbridge.dll"
windows.release.x86_64 = "res://addons/gdbridge/bin/gdbridge.dll"
linux.debug.x86_64 = "res://addons/gdbridge/bin/libgdbridge.so"
linux.release.x86_64 = "res://addons/gdbridge/bin/libgdbridge.so"
macos.debug = "res://addons/gdbridge/bin/libgdbridge.dylib"
macos.release = "res://addons/gdbridge/bin/libgdbridge.dylib"
